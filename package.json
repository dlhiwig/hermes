{
  "name": "hermes",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/main.js",
    "start:dev": "tsx src/main.ts --always-on",
    "loop:run": "tsx src/core/loop.ts",
    "loop:test": "tsx scripts/run-one-loop.ts",
    "sona:daemon": "tsx src/brain/sona.ts",
    "ledger:run": "tsx src/skills/ledger.ts",
    "demo:multi": "tsx scripts/multi-turn-demo.ts",
    "demo:fast": "tsx scripts/multi-turn-demo.ts --fast",
    "demo:mock": "tsx scripts/multi-turn-demo.ts --mock",
    "sitrep": "bash scripts/morning-sitrep.sh",
    "hermes:install": "systemctl --user enable hermes-sona && systemctl --user start hermes-sona",
    "test": "vitest run"
  },
  "dependencies": {
    "@ruvector/ruvllm": "2.5.4",
    "@ruvector/sona": "0.1.4",
    "ruflo": "3.5.51",
    "ruvector": "0.1.38",
    "typescript": "^5.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.15.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
